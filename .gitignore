# --- Folder Core Laravel (Wajib di-ignore) ---
/node_modules
/vendor
/.phpunit.cache
.phpunit.result.cache
/bootstrap/ssr
/public/build
/public/hot
/storage/pail
/auth.json
/docs

# --- Storage & Logs ---
# Kita ignore isinya, tapi tetap simpan foldernya (lewat file .gitignore di tiap folder storage)
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*.log
/storage/*.key

# Symlink storage (biasanya hasil php artisan storage:link)
/public/storage

# --- Configuration & Environment ---
.env
.env.*
!.env.example
Homestead.json
Homestead.yaml

# --- IDE & Editor Settings ---
/.fleet
/.idea
/.nova
/.vscode
/.zed
.phpactor.json

# --- Logs & Debugging ---
npm-debug.log
yarn-error.log

# --- CATATAN PENTING ---
# Folder di bawah ini DIHAPUS dari list ignore karena ini adalah SOURCE CODE:
# /resources/js/actions    <- (Jangan di-ignore)
# /resources/js/routes     <- (Jangan di-ignore)
# /resources/js/wayfinder  <- (Jangan di-ignore)